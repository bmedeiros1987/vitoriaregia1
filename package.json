{
  "name": "crewcheck-premium-github",
  "version": "10.8.4",
  "type": "module",
  "private": true,
  "description": "CrewCheck 10.8.4 Premium Total LGPD: sincronização de voos BSB pelo site oficial bsb.aero, layout desktop/mobile premium, scroll corrigido e privacidade by design.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "check": "tsc --noEmit",
    "start": "node server.mjs",
    "serve": "node server.mjs",
    "build:android:bundle": "cd android-wrapper && ./gradlew :app:bundleRelease",
    "build:android:apk": "cd android-wrapper && ./gradlew :app:assembleRelease"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.453.0",
    "pdfjs-dist": "2.16.105",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "vite": "^7.1.7",
    "wouter": "^3.3.5",
    "pg": "^8.13.1",
    "mysql2": "^3.11.5",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
