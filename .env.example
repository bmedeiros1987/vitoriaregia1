# Vitória Régia Pro v10.0 - exemplo seguro
NODE_VERSION=20.19.0
NODE_ENV=production
PORT=3000

# PostgreSQL
DATABASE_URL=cole_a_url_do_postgresql_somente_no_render
DATABASE_SSL=auto
DATABASE_SSL_MODE=auto
JWT_SECRET=troque-por-uma-chave-grande-e-forte
APP_VERSION=Vitória Régia Pro v10.0

# Administrador inicial
ADMIN_EMAIL=admin@vitoriaregia.local
ADMIN_PASSWORD=troque-esta-senha

# SendGrid
MAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=coloque-somente-no-render
SENDGRID_FROM_EMAIL=remetente-verificado@seudominio.com
SENDGRID_FROM_NAME=Condomínio Vitória Régia
SENDGRID_REPLY_TO=contato@seudominio.com
SENDGRID_TO_DEFAULT=contato@seudominio.com
SENDGRID_DATA_RESIDENCY=global

# Telegram
TELEGRAM_BOT_TOKEN=coloque-somente-no-render
TELEGRAM_CHAT_ID=opcional

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=coloque-somente-no-render
WHATSAPP_ACCESS_TOKEN=coloque-somente-no-render
WHATSAPP_API_VERSION=v19.0

# Clima/tempo exibido no painel
WEATHER_CITY=João Pessoa
WEATHER_LAT=-7.1195
WEATHER_LON=-34.8450

# Render / NPM
NPM_CONFIG_AUDIT=false
NPM_CONFIG_FUND=false
NPM_CONFIG_UPDATE_NOTIFIER=false

# Push navegador/PWA opcional
VAPID_PUBLIC_KEY=chave_publica_vapid
VAPID_PRIVATE_KEY=chave_privada_vapid
VAPID_SUBJECT=mailto:contato@seudominio.com

# Usuário acima do síndico
MASTER_EMAIL=master@vitoriaregia.local
MASTER_PASSWORD=troque_esta_senha_master

# Liberações comerciais controladas pelo Master
ENABLE_EMAIL=true
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false
ENABLE_BROWSER_PUSH=true
ENABLE_APP_PORTARIA=true
ENABLE_APP_SINDICO=true
ENABLE_APP_MORADOR=true

# Banco/boletos - segredos reais ficam no Render
BANK_PROVIDER=manual
BANK_API_BASE_URL=
BANK_CLIENT_ID=
BANK_CLIENT_SECRET=
BANK_API_TOKEN=
BANK_CERT_PATH=
BANK_KEY_PATH=

# Central de atualizações segura
ENABLE_SYSTEM_UPDATES=true
UPDATE_APPLY_MODE=github
UPDATE_GITHUB_REPO=bmedeiros1987/vitoriaregia1
UPDATE_GITHUB_BRANCH=main
UPDATE_GITHUB_TOKEN=
UPDATE_ANNOUNCE_TOKEN=
UPDATE_FEED_URL=
RENDER_DEPLOY_HOOK_URL=

UPDATE_REQUIRE_SIGNATURE=true

TELEGRAM_ENABLED=false
TELEGRAM_START_URL=https://t.me/vitoriaregia_bot
TELEGRAM_BOT_USERNAME=vitoriaregia_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PARSE_MODE=
PUBLIC_APP_URL=https://seu-sistema.onrender.com
