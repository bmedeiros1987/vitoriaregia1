# Vitória Régia - exemplo seguro de variáveis
# Copie para o Render → Environment Variables e preencha lá. Não envie senhas para o GitHub.

NODE_ENV=production
DATABASE_PROVIDER=mysql
DATABASE_URL=
MYSQL_HOST=
MYSQL_PORT=22966
MYSQL_DATABASE=defaultdb
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_SSL=true
MYSQL_SSL_MODE=REQUIRED
MYSQL_SSL_REJECT_UNAUTHORIZED=false

ADMIN_EMAILS=
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_DISABLE_AFTER_FIRST_SINDICO=false

EMAIL_ENABLED=true
EMAIL_PROVIDER=mailersend
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME="Ed. Vitória Régia"
MAILERSEND_TEST_TO=

SMTP_ENABLED=true
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="Condomínio Vitória Régia"
SMTP_TEST_TO=

TELEGRAM_ENABLED=true
TELEGRAM_PROVIDER=telegram
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_TEST_CHAT_ID=

WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=periskope
WHATSAPP_COUNTRY_CODE=55
WHATSAPP_TEST_TO=
PERISKOPE_ENABLED=true
PERISKOPE_ID=
PERISKOPE_BASE_URL=https://api.periskope.app/v1
PERISKOPE_API_URL=https://api.periskope.app/v1
PERISKOPE_API_KEY=
PERISKOPE_TOKEN=
PERISKOPE_TEST_TO=

ASAAS_ENABLED=true
ASAAS_ENVIRONMENT=production
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

SYSTEM_UPDATE_ENABLED=true
GITHUB_REPOSITORY=bmedeiros1987/vitoriaregia1
GITHUB_BRANCH=main
GITHUB_UPDATE_TOKEN=
RENDER_DEPLOY_HOOK_URL=
UPDATE_DELETE_MISSING=true
UPDATE_ZIP_LIMIT=120mb

OCR_ENABLED=true
OCR_LABEL_PROGRESS_ENABLED=true
PACKAGE_LABEL_SCAN_ENABLED=true
FINANCEIRO_MORADOR_ENABLED=true
FINANCEIRO_ADMIN_RESTRICTED=true
FINANCEIRO_PUBLICO_ENABLED=true
EMERGENCY_QUICK_ACTIONS_ENABLED=true
EMERGENCY_SHOW_USER_DETAILS=false
