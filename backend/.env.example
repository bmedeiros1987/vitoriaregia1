# =========================
# APP / RENDER
# =========================
NODE_ENV=production
PORT=10000
APP_URL=https://vitoriaregia1.onrender.com
SESSION_SECRET=troque_por_uma_chave_grande_e_aleatoria

# =========================
# BANCO AIVEN MYSQL
# Não envie senha para o GitHub. Use Render Environment Variables.
# =========================
DATABASE_PROVIDER=mysql
REQUIRE_DATABASE=true
AUTO_INIT_DB=true

MYSQL_HOST=mysql-1c3b1be8-vitoriaregia1.a.aivencloud.com
MYSQL_PORT=22966
MYSQL_DATABASE=defaultdb
MYSQL_USER=avnadmin
MYSQL_PASSWORD=COLOQUE_A_SENHA_DO_MYSQL_NO_RENDER
MYSQL_SSL=true
MYSQL_SSL_MODE=REQUIRED
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# Alternativa: DATABASE_URL completa. Use uma ou outra.
# DATABASE_URL=mysql://avnadmin:SENHA@mysql-1c3b1be8-vitoriaregia1.a.aivencloud.com:22966/defaultdb?ssl-mode=REQUIRED

# =========================
# PERFIS DO SISTEMA
# =========================
ADMIN_EMAILS=bmedeiros1987@gmail.com
PORTARIA_EMAILS=
REQUIRE_APPROVED_RESIDENT=true
ALLOW_LEGACY_DEMO_LOGIN=false

# =========================
# USUÁRIO TEMPORÁRIO DE IMPLANTAÇÃO
# =========================
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=bmedeiros1987@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=crie_uma_senha_temporaria_forte
BOOTSTRAP_ADMIN_NAME=Usuário temporário de implantação
BOOTSTRAP_DISABLE_AFTER_FIRST_SINDICO=true

# =========================
# EMAIL AUTOMÁTICO
# Provedores aceitos: mailersend ou smtp
# =========================
EMAIL_ENABLED=true
EMAIL_PROVIDER=mailersend
MAILERSEND_API_KEY=COLOQUE_O_TOKEN_MAILERSEND_NO_RENDER
MAILERSEND_FROM_NAME=Condomínio Vitória Régia
# Obrigatório se EMAIL_PROVIDER=mailersend: precisa ser remetente/domínio verificado no MailerSend
MAILERSEND_FROM_EMAIL=contato@seudominio.com.br
MAILERSEND_TEST_TO=bmedeiros1987@gmail.com

SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=bmedeiros1987@gmail.com
SMTP_APP_PASSWORD=COLOQUE_A_SENHA_DE_APP_GOOGLE_NO_RENDER
SMTP_FROM_NAME=Condomínio Vitória Régia
SMTP_FROM_EMAIL=bmedeiros1987@gmail.com
SMTP_TEST_TO=bmedeiros1987@gmail.com

# =========================
# ASAAS - BOLETOS
# =========================
ASAAS_ENABLED=false
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=COLOQUE_A_API_KEY_DO_ASAAS_NO_RENDER
ASAAS_DUE_DAYS_BEFORE=2
ASAAS_FINE_VALUE=2
ASAAS_INTEREST_VALUE=1
ASAAS_WEBHOOK_TOKEN=crie_um_token_para_validar_webhook

# =========================
# WHATSAPP - PERISKOPE, EVOLUTION API OU META CLOUD API
# =========================
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=periskope
WHATSAPP_COUNTRY_CODE=55
WHATSAPP_TEST_TO=5561999999999
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_INSTANCE=minha-instancia
EVOLUTION_API_KEY=COLOQUE_A_API_KEY_EVOLUTION_NO_RENDER
EVOLUTION_COUNTRY_CODE=55
EVOLUTION_TEST_TO=5561999999999
EVOLUTION_LINK_PREVIEW=false

# Periskope API
PERISKOPE_BASE_URL=https://api.periskope.app/v1
PERISKOPE_API_KEY=COLOQUE_A_API_KEY_PERISKOPE_NO_RENDER_SEM_BEARER
PERISKOPE_PHONE=5561999999999
# Também é aceito: PERISKOPE_PHONE=phone-xxxxxxxxxxxx
PERISKOPE_COUNTRY_CODE=55
PERISKOPE_TEST_TO=5561999999999
PERISKOPE_HIDE_URL_PREVIEW=true

WHATSAPP_API_VERSION=v20.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# =========================
# SISTEMA
# =========================
UPLOAD_MAX_MB=50
JSON_LIMIT=80mb

# =========================
# LOGIN GOOGLE / OAUTH
# =========================
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=COLOQUE_SEU_CLIENT_ID_DO_GOOGLE_NO_RENDER
GOOGLE_CLIENT_SECRET=COLOQUE_SEU_CLIENT_SECRET_DO_GOOGLE_NO_RENDER
GOOGLE_CALLBACK_URL=https://vitoriaregia1.onrender.com/auth/google/callback

# =========================
# LOGIN COM SENHA
# =========================
REQUIRE_PASSWORD_LOGIN=true
# O usuário temporário inicial continua via BOOTSTRAP_ADMIN_*; depois gere senhas temporárias pelo painel do síndico.

# =========================
# ARMAZENAMENTO EXTERNO - SUPABASE STORAGE GRATUITO
# Crie um projeto no Supabase, depois Storage > Buckets > New bucket.
# Recomendado: bucket privado chamado vitoria-regia.
# Nunca coloque SUPABASE_SERVICE_ROLE_KEY no GitHub; use apenas no Render.
# =========================
STORAGE_ENABLED=true
STORAGE_PROVIDER=supabase
STORAGE_MAX_UPLOAD_MB=50
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLOQUE_A_SERVICE_ROLE_KEY_APENAS_NO_RENDER
SUPABASE_STORAGE_BUCKET=vitoria-regia
SUPABASE_STORAGE_FOLDER=documentos
SUPABASE_STORAGE_PUBLIC=false
SUPABASE_SIGNED_URL_EXPIRES=3600

# =========================
# ARMAZENAMENTO EXTERNO - TERABOX OPCIONAL
# =========================
TERABOX_BASE_URL=https://www.terabox.com
TERABOX_UPLOAD_BASE_URL=https://c-jp.terabox.com
TERABOX_ACCESS_TOKEN=COLOQUE_O_ACCESS_TOKEN_OFICIAL_DA_TERABOX
TERABOX_ACCESS_TOKEN_PARAM=access_tokens
TERABOX_FOLDER=/vitoria-regia
TERABOX_RTYPE=1

# Telegram opcional para alertas internos
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_TEST_CHAT_ID=
TELEGRAM_PARSE_MODE=
