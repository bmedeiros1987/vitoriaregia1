{
  "name": "vitoria-regia-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Node.js para login Google, Aiven PostgreSQL e API do sistema condominial Vitória Régia.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:create": "node src/create-database.js",
    "db:init": "node src/init-db.js",
    "db:test": "node -e \"require('./src/db').pool.query('select now()').then(r=>{console.log('Conectado:', r.rows[0].now); process.exit(0)}).catch(e=>{console.error(e.message); process.exit(1)})\""
  },
  "dependencies": {
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
