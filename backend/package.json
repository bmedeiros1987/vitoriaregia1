{
  "name": "vitoria-regia-backend-operacional",
  "version": "4.4.5",
  "private": true,
  "description": "Backend Express/MySQL do Sistema Vitória Régia Premium com recuperação de senha e módulos restaurados.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "node src/init-db.js",
    "db:test": "node src/test-db.js",
    "test:email": "node src/test-email.js",
    "render:build": "npm install --omit=dev --no-audit --no-fund --legacy-peer-deps --registry=https://registry.npmjs.org/"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
